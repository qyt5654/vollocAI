<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vollocAI.ai.dao.ModelAssignmentDao">

    <insert id="insert" keyProperty="id" useGeneratedKeys="true">
        insert into model_assignment(model_id, user_id) values (#{modelId}, #{userId})
    </insert>

    <delete id="deleteByModelAndUser">
        delete from model_assignment where model_id = #{modelId} and user_id = #{userId}
    </delete>

    <delete id="deleteByModelId">
        delete from model_assignment where model_id = #{modelId}
    </delete>

    <select id="findUserIdsByModelId" resultType="java.lang.Long">
        select user_id from model_assignment where model_id = #{modelId}
    </select>

    <select id="findModelIdsByUserId" resultType="java.lang.Long">
        select model_id from model_assignment where user_id = #{userId}
    </select>

</mapper>
